  "fallback_chains": {
    "cost_optimized": {
      "description": "Prioritize cost savings with quality fallbacks",
      "chain": [
        {"provider": "openrouter-free", "conditions": ["always_try_first"]},
        {"provider": "gemini-flash", "conditions": ["if_free_fails", "moderate_complexity"]},
        {"provider": "claude-haiku", "conditions": ["if_gemini_fails", "need_reliability"]},
        {"provider": "claude-sonnet", "conditions": ["if_all_fail", "last_resort"]}
      ]
    },
    "quality_first": {
      "description": "Prioritize quality with cost-effective fallbacks",
      "chain": [
        {"provider": "claude-sonnet", "conditions": ["complex_tasks", "high_quality_needed"]},
        {"provider": "gpt-4", "conditions": ["if_claude_fails", "premium_backup"]},
        {"provider": "claude-haiku", "conditions": ["if_premium_fails", "reliable_fallback"]},
        {"provider": "gemini-flash", "conditions": ["if_all_premium_fail", "budget_option"]}
      ]
    },
    "balanced": {
      "description": "Balance cost and quality",
      "chain": [
        {"provider": "gemini-flash", "conditions": ["first_choice", "good_balance"]},
        {"provider": "claude-haiku", "conditions": ["if_gemini_fails", "similar_cost"]},
        {"provider": "claude-sonnet", "conditions": ["if_need_quality", "willing_to_pay"]},
        {"provider": "openrouter-free", "conditions": ["if_budget_exceeded", "emergency_fallback"]}
      ]
    },
    "development": {
      "description": "Optimized for development and testing",
      "chain": [
        {"provider": "openrouter-free", "conditions": ["testing", "development"]},
        {"provider": "gemini-flash", "conditions": ["need_better_quality", "still_cheap"]},
        {"provider": "claude-haiku", "conditions": ["production_testing", "moderate_cost"]},
        {"provider": "claude-sonnet", "conditions": ["final_validation", "quality_check"]}
      ]
    }
  },
  "switching_rules": {
    "budget_exceeded": {
      "trigger": "daily_cost > budget_limit",
      "action": "switch_to_tier",
      "target": "free",
      "duration": "until_budget_reset"
    },
    "provider_unhealthy": {
      "trigger": "success_rate < 80%",
      "action": "skip_provider",
      "duration": "1_hour",
      "fallback_to": "next_in_chain"
    },
    "high_latency": {
      "trigger": "avg_response_time > 10000ms",
      "action": "deprioritize_provider",
      "duration": "30_minutes",
      "fallback_to": "faster_alternative"
    },
    "rate_limited": {
      "trigger": "rate_limit_hit",
      "action": "skip_provider",
      "duration": "rate_limit_reset_time",
      "fallback_to": "next_available"
    },
    "cost_spike": {
      "trigger": "cost_per_request > tier_max * 1.5",
      "action": "switch_to_cheaper",
      "target": "lower_tier",
      "alert": true
    }
  },
